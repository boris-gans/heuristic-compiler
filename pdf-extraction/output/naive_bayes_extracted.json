            162.12998962402344
          ]
        },
        {
          "type": "text",
          "content": "^abc\nMatches some pattern abc at the start of the string\n^abc matches abc123 but not xabc123",
          "bbox": [
            135.6199951171875,
            204.83468627929688,
            883.5641479492188,
            220.52000427246094
          ]
        },
        {
          "type": "text",
          "content": "[abc]\nMatches any of a set of character\n[abc] matches a, b, or c",
          "bbox": [
            135.6199951171875,
